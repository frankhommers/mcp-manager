<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="McpManager.Views.NewTargetDialog"
        Title="Add Target"
        Width="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        SizeToContent="Height">
  <StackPanel Margin="24" Spacing="16">
    <TextBlock Text="Choose a target type" FontSize="18" FontWeight="SemiBold" />
    <TextBlock Text="Select the client you want to export MCP configs to."
               Opacity="0.75" FontSize="12" TextWrapping="Wrap" />

    <StackPanel Spacing="6" x:Name="RadioPanel">
      <RadioButton x:Name="RbClaudeDesktop" GroupName="TargetType" Content="Claude Desktop"
                   Tag="ClaudeDesktop" IsChecked="True" />
      <RadioButton x:Name="RbCodex" GroupName="TargetType" Content="Codex CLI"
                   Tag="Codex" />
      <RadioButton x:Name="RbCursor" GroupName="TargetType" Content="Cursor"
                   Tag="Cursor" />
      <RadioButton x:Name="RbWindsurf" GroupName="TargetType" Content="Windsurf"
                   Tag="Windsurf" />
      <RadioButton x:Name="RbVsCode" GroupName="TargetType" Content="VS Code"
                   Tag="VsCode" />
      <RadioButton x:Name="RbOpenCode" GroupName="TargetType" Content="OpenCode"
                   Tag="OpenCode" />
      <Separator Margin="0,4" />
      <RadioButton x:Name="RbFolder" GroupName="TargetType" Content="Project Folder"
                   Tag="Folder" />
    </StackPanel>

    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Margin="0,8,0,0">
      <Button Content="Cancel" Click="CancelButton_OnClick"
              Width="80" HorizontalContentAlignment="Center" CornerRadius="14" />
      <Button Content="Add" Click="AddButton_OnClick"
              Width="80" HorizontalContentAlignment="Center" CornerRadius="14"
              Classes="primaryButton" />
    </StackPanel>
  </StackPanel>
</Window>
